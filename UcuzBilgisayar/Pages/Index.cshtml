@page
@model IndexModel
@{
    ViewData["Title"] = "Ana sayfa";
}

@{
    var products = "";
    ProductsHandler handler = new ProductsHandler();
    foreach (Product product in handler.products)
    {
        products += string.Format("""
            <div class="card">
                <b>Ürün:</b> {0}                
                <br>          
                <b>Marka:</b> {1}
                <br>
                <b>Fiyat:</b> {2}
                <br>
                <b>Puan:</b> {3}
                <br>
                <b>Yorum Sayısı:</b> {4}
            </div>
        """, product.name, product.brand, product.price, product.rating, product.reviews);
    }

}

<div id="container">
    <div class="text-center title">
        <h1 class="display-4">Ucuz Bilgisayar</h1>
        <p>En ucuz bilgisayar fiyatlarını öğrenin.</a></p>
    </div>

    <div class="search-bar center">
        <input class="center" type="text" id="search-bar" />
    </div>

    <div id="info-and-sort">
        <div class="info">
            Bilgisayar ürünleri gösteriliyor.
        </div>

        <div class="sort-buttons">
            <div id="sort-button">
                <a>Varsayılan sıraya göre</a>
            </div>      

            <div class="sort-options">
                <div class="sort-lowest-price sort-button">
                    <a>En düşük fiyat</a>
                </div>
                <div class="sort-highest-price sort-button">
                    <a>En yüksek fiyat</a>
                </div>
                <div class="sort-highest-reviews sort-button">
                    <a>Çok değerlendirilenler</a>
                </div>
                <div class="sort-highest-ratings sort-button">
                    <a>Yüksek puanlılar</a>
                </div>
            </div>
        </div>
        
        
    </div>

    <div class="cards">
        @Html.Raw(products)
    </div>
</div>