@page
@model IndexModel
@{

}

@{
	var products = "";

	ProductsHandler handler = new ProductsHandler();
	foreach (Product product in handler.products)
	{
		String[] price = product.price.Split(",");
		String priceWhole = price[0];
		int j = 0;
		for (int i = priceWhole.Length - 1; i > 0; i--)
		{
			if (j == 2)
			{
				priceWhole = priceWhole.Insert(i, ",");
				j = -1;
			}
			j++;
		}


		products += string.Format("""
            <div class="card">
                <b>Ürün:</b> {0}                
                <br>          
                <b>Marka:</b> {1}
                <br>
                <b>Fiyat:</b> {2}₺
                <br>
                <b>Puan:</b> {3}
                <br>
                <b>Yorum Sayısı:</b> {4}
            </div>
        """, product.name, product.brand, priceWhole, product.rating, product.reviews);
    }

}

